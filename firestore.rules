rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // Helper functions
    // ──────────────────────────────────────────────────────────────

    // True if the request comes from a signed-in user (including anonymous).
    function isAuthenticated() {
      return request.auth != null;
    }

    // Matches the CEO email that is hard-coded throughout every admin page.
    // home.html auto-sets role == 'admin' for this account on first sign-in,
    // so isCEO() is a safety net for the very first login before that write
    // completes.  To change the owner, update the email here AND in the app code.
    function isCEO() {
      return isAuthenticated() && request.auth.token.email == 'pwavwef@gmail.com';
    }

    // Read the requesting user's document once, used by role helpers.
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // True when the caller's role field matches the given value.
    function hasRole(role) {
      return isAuthenticated() && userData().role == role;
    }

    // Full admin: either the CEO or a user with role == 'admin'.
    function isAdmin() {
      return isCEO() || hasRole('admin');
    }

    // True if the caller is an admin OR has the specific division role.
    function isAdminOrRole(role) {
      return isAdmin() || hasRole(role);
    }

    // Banned users must not access anything.
    function notBanned() {
      return isAuthenticated() && userData().role != 'banned';
    }

    // ──────────────────────────────────────────────────────────────
    // USERS
    // ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user may read any profile (required for leaderboard,
      // profile pages, and role checks in security rules themselves).
      allow read: if isAuthenticated();

      // A user may create only their own document.
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // A user may update their own document, but cannot change their own role.
      // Admins may update any user document, including the role field.
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      );

      // Only admins may delete user documents.
      allow delete: if isAdmin();

      // ── User subcollections ──────────────────────────────────────
      match /tickets/{ticketId} {
        allow read, write: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
      }

      match /private_tasks/{taskId} {
        allow read, write: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
      }

      match /quick_links/{linkId} {
        allow read, write: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
      }

      match /personal_data/{docId} {
        allow read, write: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
      }
    }

    // ──────────────────────────────────────────────────────────────
    // BLOGS
    // ──────────────────────────────────────────────────────────────
    match /blogs/{blogId} {
      allow read: if notBanned();

      // Only the blog owner may create the document and must tag it with their uid.
      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      // Owner or admin may update any field.
      // Any authenticated user may update only social-interaction fields.
      allow update: if notBanned() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['likes', 'dislikes', 'reposts', 'replyCount'])
      );

      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────────────────
    // BLOG COMMENTS
    // ──────────────────────────────────────────────────────────────
    match /blog_comments/{commentId} {
      allow read: if notBanned();

      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────────────────
    // COURSES
    // ──────────────────────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if notBanned();

      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────────────────
    // ASSIGNMENTS
    // ──────────────────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────────────────
    // NOTES
    // ──────────────────────────────────────────────────────────────
    match /notes/{noteId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────────────────
    // EVENTS
    // ──────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if notBanned();

      allow create, delete: if isAdmin();

      // Admins may update anything; regular users may only update
      // the rsvp list and ticket counter (for RSVP / ticket purchase).
      allow update: if isAdmin() || (
        notBanned() &&
        request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['rsvps', 'ticketsSold'])
      );
    }

    // ──────────────────────────────────────────────────────────────
    // GLOBAL ANNOUNCEMENTS
    // ──────────────────────────────────────────────────────────────
    match /global_announcements/{announcementId} {
      allow read: if notBanned();
      allow write: if isAdminOrRole('admin_assistant');
    }

    // ──────────────────────────────────────────────────────────────
    // USER NOTIFICATIONS
    // ──────────────────────────────────────────────────────────────
    match /user_notifications/{notifId} {
      // Users may read/update/delete their own notifications.
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // Only the system (admin-role callers) creates notifications.
      allow create: if isAdmin();

      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────────────────
    // FEEDBACK / REVIEWS
    // ──────────────────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow read: if isAdmin();

      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────────────────
    // PRINT ORDERS  (document ID == user UID)
    // ──────────────────────────────────────────────────────────────
    match /print_orders/{orderId} {
      allow read: if isAuthenticated() &&
        (orderId == request.auth.uid || isAdmin());

      allow create: if isAuthenticated() &&
        (orderId == request.auth.uid || isAdmin());

      allow update: if isAuthenticated() &&
        (orderId == request.auth.uid || isAdmin());

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // PRINT MESSAGES
    // ──────────────────────────────────────────────────────────────
    match /print_messages/{msgId} {
      // orderId == user's UID, so users can query their own chat messages.
      allow read: if isAuthenticated() && (
        resource.data.orderId == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // DIRECT CHATS  (document ID = sorted pair of UIDs)
    // ──────────────────────────────────────────────────────────────
    match /direct_chats/{chatId} {
      allow read, update: if isAuthenticated() &&
        request.auth.uid in resource.data.users;

      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.users;

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // PAST QUESTIONS & COURSES
    // ──────────────────────────────────────────────────────────────
    match /pq_courses/{courseId} {
      allow read: if notBanned();
      allow write: if isAdmin();
    }

    match /past_questions/{questionId} {
      allow read: if notBanned();
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // REPORTS
    // ──────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();

      allow create: if notBanned() &&
        request.resource.data.reporterId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // SERVICE REQUESTS
    // ──────────────────────────────────────────────────────────────
    match /service_requests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdminOrRole('admin_assistant'));

      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdminOrRole('admin_assistant')
      );

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // CV ORDERS
    // ──────────────────────────────────────────────────────────────
    match /cv_orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if notBanned() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // SURVEY RESPONSES
    // ──────────────────────────────────────────────────────────────
    match /surveyResponses/{responseId} {
      allow read: if isAdmin();

      // Anonymous users (signInAnonymously) are still "authenticated" and
      // may submit survey responses.
      allow create: if isAuthenticated();

      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // SYSTEM / CONFIG
    // ──────────────────────────────────────────────────────────────
    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // PODCAST
    // ──────────────────────────────────────────────────────────────
    match /podcast_episodes/{episodeId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrRole('podcast_lead');
    }

    match /podcast_guests/{guestId} {
      allow read, write: if isAdminOrRole('podcast_lead');
    }

    match /podcast_schedule/{scheduleId} {
      allow read, write: if isAdminOrRole('podcast_lead');
    }

    match /podcast_scripts/{scriptId} {
      allow read, write: if isAdminOrRole('podcast_lead');
    }

    // ──────────────────────────────────────────────────────────────
    // AMBASSADOR PROGRAMME
    // ──────────────────────────────────────────────────────────────
    match /ambassador_applications/{appId} {
      // Any authenticated user may apply.
      allow create: if isAuthenticated();

      allow read, update, delete: if isAdminOrRole('chief_ambassador');
    }

    match /ambassadors/{ambassadorId} {
      // Ambassadors leaderboard is visible to all authenticated users.
      allow read: if isAuthenticated();
      allow write: if isAdminOrRole('chief_ambassador');
    }

    match /ambassador_programs/{programId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrRole('chief_ambassador');
    }

    match /ambassador_challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrRole('chief_ambassador');
    }

    match /ambassador_resources/{resourceId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrRole('chief_ambassador');
    }

    // ──────────────────────────────────────────────────────────────
    // FINANCE
    // ──────────────────────────────────────────────────────────────
    match /financial_journal/{entryId} {
      allow read, write: if isAdminOrRole('finance_lead');
    }

    match /finance_budget/{budgetId} {
      allow read, write: if isAdminOrRole('finance_lead');
    }

    // ──────────────────────────────────────────────────────────────
    // DEVELOPER DIVISION
    // ──────────────────────────────────────────────────────────────
    match /dev_projects/{projectId} {
      allow read, write: if isAdminOrRole('developer');
    }

    match /dev_issues/{issueId} {
      allow read, write: if isAdminOrRole('developer');
    }

    match /dev_deployments/{deployId} {
      allow read, write: if isAdminOrRole('developer');
    }

    match /dev_logs/{logId} {
      allow read, write: if isAdminOrRole('developer');
    }

    // ──────────────────────────────────────────────────────────────
    // MARKETING DIVISION
    // ──────────────────────────────────────────────────────────────
    match /mkt_campaigns/{campaignId} {
      allow read, write: if isAdminOrRole('marketing_lead');
    }

    match /mkt_content/{contentId} {
      allow read, write: if isAdminOrRole('marketing_lead');
    }

    match /mkt_metrics/{metricId} {
      allow read, write: if isAdminOrRole('marketing_lead');
    }

    match /mkt_posts/{postId} {
      allow read, write: if isAdminOrRole('marketing_lead');
    }

    // ──────────────────────────────────────────────────────────────
    // ADMIN-ONLY COLLECTIONS
    // ──────────────────────────────────────────────────────────────
    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /admin_team_tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    match /admin_hq_chat/{msgId} {
      allow read, write: if isAdmin();
    }

    match /admin_vault_files/{fileId} {
      allow read, write: if isAdmin();
    }

    match /admin_petitions/{petitionId} {
      allow read, write: if isAdmin();
    }

    match /admin_tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    match /workspace_messages/{msgId} {
      allow read, write: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // ADMIN ASSISTANT DIVISION
    // ──────────────────────────────────────────────────────────────
    match /assist_tasks/{taskId} {
      allow read, write: if isAdminOrRole('admin_assistant');
    }

    match /assist_meetings/{meetingId} {
      allow read, write: if isAdminOrRole('admin_assistant');
    }

    match /assist_announcements/{announcementId} {
      allow read, write: if isAdminOrRole('admin_assistant');
    }

    match /assist_docs/{docId} {
      allow read, write: if isAdminOrRole('admin_assistant');
    }

    // ──────────────────────────────────────────────────────────────
    // ARTIFACTS / CANVAS DATA  (nested public data store)
    // ──────────────────────────────────────────────────────────────
    match /artifacts/{appId}/public/data/{collection}/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
